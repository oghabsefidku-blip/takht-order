<html>

<head>

<title>System Starter</title>

<hta:application
border="thin"
caption="yes"
showintaskbar="yes"
singleinstance="yes"
windowstate="normal"
/>

<meta charset="UTF-8">

<style>

body{
background:#0f172a;
color:white;
font-family:tahoma;
text-align:center;
padding-top:80px;
}

button{
font-size:26px;
padding:20px 45px;
border:none;
border-radius:15px;
background:#22c55e;
color:white;
cursor:pointer;
}

button:hover{
background:#16a34a;
}

</style>

<script>

function startSystem(){

var shell = new ActiveXObject("WScript.Shell");

shell.Run("start-system.bat",1,false);

}

</script>

</head>

<body dir="rtl">

<h2>راه اندازی سیستم سفارش</h2>

<button onclick="startSystem()">

اجرای سرور و تونل

</button>

</body>

</html>